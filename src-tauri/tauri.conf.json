{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "axon",
  "version": "0.1.0",
  "identifier": "com.axon.term",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Axon",
        "theme": "Light",
        "width": 1024,
        "height": 768,
        "minWidth": 720,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "skipTaskbar": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 24
        },
        "hiddenTitle": true,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://avatars.githubusercontent.com blob: data:; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": {
      "macos": ["dmg", "app"],
      "windows": ["nsis", "msi"],
      "linux": ["deb", "appimage"]
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}